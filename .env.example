# AI providers — server-only, never exposed to the client. Gemini and
# Featherless both use OpenAI-compatible endpoints. Netlify production can
# alternatively use AI Gateway when it injects OPENAI_API_KEY + OPENAI_BASE_URL.
# When no provider is available, the app preserves the original question and
# offers a separately selected validated demo instead of silently substituting.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

FEATHERLESS_API_KEY=
FEATHERLESS_TEXT_MODEL=Qwen/Qwen3-32B
FEATHERLESS_VISION_MODEL=Qwen/Qwen3-VL-30B-A3B-Instruct

# Optional overrides
# GEMINI_VISION_MODEL=gemini-3.5-flash
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# GEMINI_TIMEOUT_MS=60000
# FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
# FEATHERLESS_TIMEOUT_MS=20000

# Optional Netlify AI Gateway model overrides (credentials are injected).
# NETLIFY_AI_MODEL=gpt-5.4-mini
# NETLIFY_AI_VISION_MODEL=gpt-5.4-mini
