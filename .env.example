# Featherless AI (OpenAI-compatible) — server-only, never exposed to the client.
# Without FEATHERLESS_API_KEY the app still works: the compiler serves bundled
# fixtures and the evaluator uses a deterministic heuristic rubric.
FEATHERLESS_API_KEY=
FEATHERLESS_TEXT_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct
FEATHERLESS_VISION_MODEL=Qwen/Qwen2.5-VL-7B-Instruct

# Optional overrides
# FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
# FEATHERLESS_TIMEOUT_MS=20000
