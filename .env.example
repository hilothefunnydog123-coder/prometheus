# Featherless AI (OpenAI-compatible) — server-only, never exposed to the client.
# Optional explicit provider. Netlify production deployments can use Netlify
# AI Gateway when it injects OPENAI_API_KEY + OPENAI_BASE_URL. Local
# `next dev` can use Featherless directly. When no provider is available, the
# learner-facing app preserves the original question and offers a separate,
# explicitly selected validated demo instead of silently substituting it.
FEATHERLESS_API_KEY=
FEATHERLESS_TEXT_MODEL=Qwen/Qwen3-32B
FEATHERLESS_VISION_MODEL=Qwen/Qwen3-VL-30B-A3B-Instruct

# Optional overrides
# FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
# FEATHERLESS_TIMEOUT_MS=20000

# Optional Netlify AI Gateway model overrides (credentials are injected).
# NETLIFY_AI_MODEL=gpt-5.4-mini
# NETLIFY_AI_VISION_MODEL=gpt-5.4-mini
