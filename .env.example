# Featherless AI (OpenAI-compatible) — server-only, never exposed to the client.
# Without FEATHERLESS_API_KEY the app still works: the compiler serves bundled
# fixtures (disclosed via warnings, provenance "validated-example") and the
# evaluator uses a deterministic heuristic rubric.
FEATHERLESS_API_KEY=
FEATHERLESS_TEXT_MODEL=Qwen/Qwen3-32B
FEATHERLESS_VISION_MODEL=google/gemma-3-27b-it

# Optional overrides
# FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
# FEATHERLESS_TIMEOUT_MS=20000
